# Copy to ~/.config/bdstorage/env (the install script does this for you).
# bdstorage resolves state under $HOME/.imprint/ (state DB and vault).

HOME=/home/YOUR_WSL_USER
BDSTORAGE_BIN=/home/YOUR_WSL_USER/path/to/bdstorage/target/release/bdstorage
BDSTORAGE_TARGET=/home/YOUR_WSL_USER/path/to/files-to-dedupe
BDSTORAGE_INTERVAL_SECS=3600
