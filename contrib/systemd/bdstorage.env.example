# Install as /etc/bdstorage.env (mode 0600). Used by bdstorage-dedupe*.service.
#
# bdstorage stores state under $HOME/.imprint/ (database and vault). The service units
# set User=bdstorage; HOME should match that account's home (usually /var/lib/bdstorage).

HOME=/var/lib/bdstorage
BDSTORAGE_TARGET=/srv/data
BDSTORAGE_INTERVAL_SECS=3600
